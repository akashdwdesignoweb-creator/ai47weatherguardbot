# Port configuration
PORT=5000

# MongoDB Connection String (use local or Atlas URI)
MONGODB_URI=mongodb://localhost:27017/weatherguard

# JWT Secret
JWT_SECRET=super-secret-jwt-key-change-in-production

# Telegram Bot configuration
# Create a bot with @BotFather to get this token
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Weather API Configuration (Optional)
# Leave blank to use free keyless Open-Meteo API
OPENWEATHER_API_KEY=

# Frontend Redirect Url
FRONTEND_URL=http://localhost:5173

# Real Google OAuth Configuration (Optional, for production social logins)
# Create credentials in Google Developer Console
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Real GitHub OAuth Configuration (Optional, for production social logins)
# Create credentials in GitHub Developer Settings
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback
